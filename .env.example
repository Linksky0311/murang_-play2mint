# ============================================================
#  ⚠️  주의: 반드시 "테스트 전용" 지갑의 개인키만 사용하세요.
#  메인넷 자산이 있는 지갑의 키는 절대 넣지 마세요.
#  .env 파일은 .gitignore에 포함되어 있어 커밋되지 않습니다.
# ============================================================

# Sepolia 테스트 지갑의 개인키 (0x 접두사 있어도 없어도 OK)
PRIVATE_KEY=

# Sepolia RPC URL (비워두면 공용 RPC 자동 사용)
# 더 안정적인 게 필요하면 Alchemy/Infura 키 발급해서 넣으세요.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
